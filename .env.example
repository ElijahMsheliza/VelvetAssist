# Supabase Auth & DB
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Required for webhook to bypass RLS. Get from: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI for Magic Link Chat
OPENAI_API_KEY=sk-...

# Stripe for Subscription Gate
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
# Required for webhook signature verification. Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin Panel
# Server-side ONLY (no NEXT_PUBLIC_ prefix). Set to your Supabase account email.
# Users who sign in via /login with this email get access to /admin.
ADMIN_EMAIL=dashwave19@gmail.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
NEXT_PUBLIC_SITE_URL=http://localhost:3000
